---
/**
 * Breadcrumb — usa-breadcrumb
 * https://designsystem.digital.gov/components/breadcrumb/
 */

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  /** Allow long labels to wrap to multiple lines */
  wrap?: boolean;
  class?: string;
}

import { withBase } from '../../i18n/utils';

const { items, wrap = false, class: className } = Astro.props;
---

<nav
  class:list={['usa-breadcrumb', wrap && 'usa-breadcrumb--wrap', className]}
  aria-label="Breadcrumbs"
>
  <ol class="usa-breadcrumb__list">
    {items.map((item, i) => {
      const isCurrent = i === items.length - 1;
      return (
        <li
          class:list={['usa-breadcrumb__list-item', isCurrent && 'usa-current']}
          aria-current={isCurrent ? 'page' : undefined}
        >
          {isCurrent || !item.href ? (
            <span>{item.label}</span>
          ) : (
            <a href={withBase(item.href)} class="usa-breadcrumb__link">
              <span>{item.label}</span>
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>
