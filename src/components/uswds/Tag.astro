---
/**
 * Tag — usa-tag
 * https://designsystem.digital.gov/components/tag/
 *
 * Small label for status, category, or metadata.
 */

interface Props {
  /**
   * Background color applied via usa-tag--{color} or a USWDS bg- utility class.
   * USWDS standard status colors: 'new' | 'informative' | 'cool' | 'warn' | 'error' | 'success'
   * Pass any string to use arbitrary USWDS color tokens.
   */
  color?: string;
  /** Larger font size */
  big?: boolean;
  class?: string;
}

const { color, big = false, class: className } = Astro.props;
---

<span
  class:list={[
    'usa-tag',
    color && `usa-tag--${color}`,
    big && 'usa-tag--big',
    className,
  ]}
>
  <slot />
</span>
