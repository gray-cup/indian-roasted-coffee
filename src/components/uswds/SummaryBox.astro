---
/**
 * SummaryBox — usa-summary-box
 * https://designsystem.digital.gov/components/summary-box/
 *
 * Highlighted key-information box, typically in a sidebar.
 * Pairs well with eligibility facts, apply CTAs, and contact info.
 */

interface Props {
  heading: string;
  /** ARIA label for the complementary landmark */
  label?: string;
  class?: string;
}

const { heading, label, class: className } = Astro.props;
---

<div
  class:list={['usa-summary-box', className]}
  role="complementary"
  aria-label={label ?? heading}
>
  <div class="usa-summary-box__body">
    <h2 class="usa-summary-box__heading">{heading}</h2>
    <div class="usa-summary-box__text">
      <slot />
    </div>
  </div>
</div>
