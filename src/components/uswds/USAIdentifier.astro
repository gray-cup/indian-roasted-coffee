---
import type { Locale } from '../../i18n/utils';
import { useTranslations, withBase } from '../../i18n/utils';
import { siteConfig } from '../../config/site';

interface Props {
  locale?: Locale;
  agencyFullName?: string;
  agencyUrl?: string;
  logoSrc?: string;
}

const {
  locale = 'en',
  agencyFullName = siteConfig.name,
  agencyUrl = `https://${siteConfig.domain}`,
  logoSrc,
} = Astro.props;

const t = useTranslations(locale);
const links = siteConfig.links;
---

<div class="usa-identifier">
  <section
    class="usa-identifier__section usa-identifier__section--masthead"
    aria-label="Store identifier"
  >
    <div class="usa-identifier__container">
      {logoSrc && (
        <div class="usa-identifier__logos">
          <a href={agencyUrl} class="usa-identifier__logo">
            <img
              class="usa-identifier__logo-img"
              src={logoSrc}
              alt={t('identifier.logoAlt')}
            />
          </a>
        </div>
      )}
      <section
        class="usa-identifier__identity"
        aria-label="Store description"
      >
        <p class="usa-identifier__identity-domain">{siteConfig.domain}</p>
        <p class="usa-identifier__identity-disclaimer">
          {t('identifier.disclaimer')}{' '}
          <a href={agencyUrl}>{agencyFullName}</a>
        </p>
      </section>
    </div>
  </section>

  <nav
    class="usa-identifier__section usa-identifier__section--required-links"
    aria-label={t('identifier.linksLabel')}
  >
    <div class="usa-identifier__container">
      <ul class="usa-identifier__required-links-list">
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.about)} class="usa-identifier__required-link usa-link">
            {t('identifier.about')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.accessibility)} class="usa-identifier__required-link usa-link">
            {t('identifier.accessibility')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.foia)} class="usa-identifier__required-link usa-link">
            {t('identifier.foia')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.noFear)} class="usa-identifier__required-link usa-link">
            {t('identifier.noFear')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.oig)} class="usa-identifier__required-link usa-link">
            {t('identifier.oig')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.privacy)} class="usa-identifier__required-link usa-link">
            {t('identifier.privacy')}
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href={withBase(links.budget)} class="usa-identifier__required-link usa-link">
            {t('identifier.budget')}
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <section
    class="usa-identifier__section usa-identifier__section--usagov"
    aria-label="Coffee Board of India"
  >
    <div class="usa-identifier__container">
      <div class="usa-identifier__usagov-description">
        {t('identifier.usagovDescription')}
      </div>
      <a href={links.usagov} class="usa-link" rel="noreferrer">
        {t('identifier.usagovLink')}
      </a>
    </div>
  </section>
</div>
