---
/**
 * ProcessListItem — single step inside a <ProcessList>.
 * Heading level can be adjusted to fit document outline.
 */

interface Props {
  heading: string;
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { heading, headingLevel: HeadingTag = 'h3' } = Astro.props;
---

<li class="usa-process-list__item">
  <HeadingTag class="usa-process-list__heading">{heading}</HeadingTag>
  <slot />
</li>
