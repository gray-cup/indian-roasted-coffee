---
/**
 * SideNav — usa-sidenav
 * https://designsystem.digital.gov/components/side-navigation/
 *
 * Vertical navigation for section sub-pages (help topics, policy sections, etc.)
 */

interface NavItem {
  label: string;
  href: string;
  current?: boolean;
  children?: NavItem[];
}

interface Props {
  items: NavItem[];
  label?: string;
  class?: string;
}

import { withBase } from '../../i18n/utils';

const { items, label = 'Section navigation', class: className } = Astro.props;
---

<nav aria-label={label} class={className}>
  <ul class="usa-sidenav">
    {items.map((item) => (
      <li class:list={['usa-sidenav__item', item.current && 'usa-current']}>
        <a
          href={withBase(item.href)}
          aria-current={item.current ? 'page' : undefined}
        >
          {item.label}
        </a>
        {item.children && item.children.length > 0 && (
          <ul class="usa-sidenav__sublist">
            {item.children.map((child) => (
              <li class:list={['usa-sidenav__item', child.current && 'usa-current']}>
                <a
                  href={withBase(child.href)}
                  aria-current={child.current ? 'page' : undefined}
                >
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>
