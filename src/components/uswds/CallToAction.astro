---
/**
 * CallToAction — usa-callout / full-width CTA section
 *
 * Not a named USWDS component, but composes standard USWDS
 * utility classes and the button pattern for a common gov-site need:
 * a full-width colored band with heading, body text, and a button.
 *
 * Use on homepages and service pages to drive users toward apply flows.
 */

interface Props {
  heading: string;
  body?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Background color token — USWDS utility class suffix */
  bg?: 'primary-darker' | 'primary' | 'accent-cool' | 'base-lightest';
  /** Text color — 'white' when bg is dark */
  textColor?: 'white' | 'ink';
  class?: string;
}

import { withBase } from '../../i18n/utils';

const {
  heading,
  body,
  primaryCta,
  secondaryCta,
  bg = 'primary-darker',
  textColor = 'white',
  class: className,
} = Astro.props;

const headingId = `cta-heading-${crypto.randomUUID().slice(0, 8)}`;
---

<section
  class:list={[`bg-${bg}`, 'usa-section', className]}
  aria-labelledby={headingId}
>
  <div class="grid-container">
    <h2
      id={headingId}
      class:list={[
        'font-heading-xl',
        textColor === 'white' && 'text-white',
      ]}
    >
      {heading}
    </h2>
    {body && (
      <p class:list={['usa-intro', textColor === 'white' && 'text-white']}>
        {body}
      </p>
    )}
    <slot />
    {(primaryCta || secondaryCta) && (
      <div class="margin-top-4">
        {primaryCta && (
          <a
            href={withBase(primaryCta.href)}
            class:list={[
              'usa-button',
              'usa-button--big',
              textColor === 'white' && 'usa-button--outline usa-button--inverse',
            ]}
          >
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a
            href={withBase(secondaryCta.href)}
            class:list={[
              'usa-button',
              'usa-button--unstyled',
              'margin-left-3',
              textColor === 'white' && 'text-white',
            ]}
          >
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
