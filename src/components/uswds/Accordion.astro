---
/**
 * Accordion — usa-accordion
 * https://designsystem.digital.gov/components/accordion/
 *
 * Requires USWDS JS (loaded in BaseLayout) for open/close behavior.
 *
 * Usage:
 *   <Accordion items={[{ heading: 'Q?', content: 'A.' }]} />
 *
 * Or with slot-based content using AccordionItem (see below).
 */

interface AccordionItem {
  heading: string;
  /**
   * Rendered as raw HTML via set:html — NEVER pass unsanitized
   * user- or CMS-supplied content here (XSS risk). For untrusted
   * content, use the slot-based <AccordionItem> API with text children.
   */
  content?: string;
  expanded?: boolean;
  id?: string;
}

interface Props {
  items?: AccordionItem[];
  /** Allow multiple panels open simultaneously */
  multiselectable?: boolean;
  /** Bordered variant */
  bordered?: boolean;
  class?: string;
}

const {
  items,
  multiselectable = true,
  bordered = false,
  class: className,
} = Astro.props;

// Auto-generate IDs when not provided
const uid = crypto.randomUUID().slice(0, 8);
const resolvedItems = items?.map((item, i) => ({
  ...item,
  id: item.id ?? `accordion-item-${uid}-${i}`,
}));
---

<div
  class:list={['usa-accordion', bordered && 'usa-accordion--bordered', className]}
  data-allow-multiple={multiselectable ? '' : undefined}
>
  {resolvedItems ? (
    resolvedItems.map((item) => (
      <div class="usa-accordion__item">
        <h3 class="usa-accordion__heading">
          <button
            type="button"
            class="usa-accordion__button"
            aria-expanded={item.expanded ? 'true' : 'false'}
            aria-controls={item.id}
          >
            {item.heading}
          </button>
        </h3>
        <div
          id={item.id}
          class="usa-accordion__content usa-prose"
          hidden={!item.expanded}
          set:html={item.content}
        />
      </div>
    ))
  ) : (
    /* Slot-based usage: pass <AccordionItem> children */
    <slot />
  )}
</div>
