---
import type { Locale } from '../../i18n/utils';
import { useTranslations, localizeUrl } from '../../i18n/utils';
import { siteConfig } from '../../config/site';
import CartButton from '../CartButton.astro';

interface NavLink {
  label: string;
  href: string;
  current?: boolean;
}

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;

const navLinks: NavLink[] = [
  {
    label: locale === 'es' ? 'Productos' : 'Products',
    href: localizeUrl('/services/', locale),
    current: currentPath.startsWith('/services') || currentPath.startsWith('/es/services'),
  },
  {
    label: locale === 'es' ? 'Mayorista' : 'Wholesale',
    href: localizeUrl('/wholesale/', locale),
    current: currentPath === '/wholesale/' || currentPath === '/es/wholesale/',
  },
  {
    label: locale === 'es' ? 'Contacto' : 'Contact',
    href: localizeUrl('/contact/', locale),
    current: currentPath === '/contact/' || currentPath === '/es/contact/',
  },
  {
    label: locale === 'es' ? 'Acerca de' : 'About',
    href: localizeUrl('/about/', locale),
    current: currentPath === '/about/' || currentPath === '/es/about/',
  },
];
---

<header class="usa-header usa-header--basic">
  <div class="usa-nav-container">
    <div class="usa-navbar">
      <div class="usa-logo">
        <em class="usa-logo__text">
          <a href={localizeUrl('/', locale)} title={t('site.name')} aria-label={t('site.name')}>
            {siteConfig.name}
          </a>
        </em>
      </div>
      <button
        type="button"
        class="usa-menu-btn"
        aria-label={t('nav.menu')}
      >
        {t('nav.menu')}
      </button>
    </div>

    <nav
      aria-label={t('nav.primary')}
      class="usa-nav"
    >
      <button type="button" class="usa-nav__close" aria-label={t('nav.close')}>
        <img src={`${base}uswds/img/usa-icons/close.svg`} role="img" alt="" />
      </button>

      <ul class="usa-nav__primary usa-accordion">
        {navLinks.map((link) => (
          <li class="usa-nav__primary-item">
            <a
              href={link.href}
              class:list={['usa-nav-link', { 'usa-current': link.current }]}
              aria-current={link.current ? 'page' : undefined}
            >
              <span>{link.label}</span>
            </a>
          </li>
        ))}
        <li class="usa-nav__primary-item nav-cart-item">
          <CartButton locale={locale} />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-cart-item {
    display: flex;
    align-items: center;
    margin-left: auto;
  }
</style>
