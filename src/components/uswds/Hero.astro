---
/**
 * Hero — usa-hero
 * https://designsystem.digital.gov/components/hero/
 *
 * Full-width hero section for page headers and landing pages.
 */

interface Props {
  /** Primary heading — use span children for the two-color split */
  heading: string;
  /** Optional secondary heading suffix in normal weight */
  headingSuffix?: string;
  /** Subheading / intro paragraph */
  subheading?: string;
  /** CTA button label */
  ctaText?: string;
  /** CTA button href */
  ctaHref?: string;
  /** Background image URL (optional — USWDS provides default) */
  backgroundSrc?: string;
  /** Smaller variant with less vertical padding */
  small?: boolean;
  /** Accessible label for the section landmark */
  label?: string;
  class?: string;
}

import { withBase } from '../../i18n/utils';

const {
  heading,
  headingSuffix,
  subheading,
  ctaText,
  ctaHref,
  backgroundSrc,
  small = false,
  label = 'Introduction',
  class: className,
} = Astro.props;
---

<section
  class:list={['usa-hero', small && 'usa-hero--small', className]}
  aria-label={label}
  style={backgroundSrc ? `background-image: url('${backgroundSrc}')` : undefined}
>
  <div class="grid-container">
    <div class="usa-hero__callout">
      <h1 class="usa-hero__heading">
        {headingSuffix ? (
          <>
            <span class="usa-hero__heading--alt">{heading}</span>
            {headingSuffix}
          </>
        ) : heading}
      </h1>
      {subheading && <p>{subheading}</p>}
      {ctaText && ctaHref && (
        <a class="usa-button usa-button--big" href={withBase(ctaHref)}>
          {ctaText}
        </a>
      )}
      <slot />
    </div>
  </div>
</section>
