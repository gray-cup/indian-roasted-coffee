---
/**
 * AccordionItem — individual panel for use inside <Accordion>
 *
 * Usage:
 *   <Accordion>
 *     <AccordionItem heading="Question?" expanded>Answer text.</AccordionItem>
 *     <AccordionItem heading="Another?">More text.</AccordionItem>
 *   </Accordion>
 */

interface Props {
  heading: string;
  expanded?: boolean;
  id?: string;
  /** Heading level to render — defaults to h3 */
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const {
  heading,
  expanded = false,
  id = `accordion-${crypto.randomUUID().slice(0, 8)}`,
  headingLevel: HeadingTag = 'h3',
} = Astro.props;
---

<div class="usa-accordion__item">
  <HeadingTag class="usa-accordion__heading">
    <button
      type="button"
      class="usa-accordion__button"
      aria-expanded={expanded ? 'true' : 'false'}
      aria-controls={id}
    >
      {heading}
    </button>
  </HeadingTag>
  <div
    id={id}
    class="usa-accordion__content usa-prose"
    hidden={!expanded}
  >
    <slot />
  </div>
</div>
