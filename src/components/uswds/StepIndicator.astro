---
/**
 * StepIndicator — usa-step-indicator
 * https://designsystem.digital.gov/components/step-indicator/
 *
 * Shows multi-step progress in application flows.
 * Used by ApplyLayout; can also be used standalone.
 */

interface Step {
  label: string;
}

interface Props {
  steps: Step[];
  /** 1-based current step number */
  currentStep: number;
  /** Show step numbers in circles */
  counters?: boolean;
  /** Smaller counter variant */
  countersSm?: boolean;
  /** Center the labels below each segment */
  centered?: boolean;
  /** Screen reader label for the overall nav */
  label?: string;
}

const {
  steps,
  currentStep,
  counters = true,
  countersSm = false,
  centered = false,
  label = 'Progress steps',
} = Astro.props;
---

<div
  class:list={[
    'usa-step-indicator',
    counters && !countersSm && 'usa-step-indicator--counters',
    countersSm && 'usa-step-indicator--counters-sm',
    centered && 'usa-step-indicator--center',
  ]}
  role="group"
  aria-label={label}
>
  <ol class="usa-step-indicator__segments">
    {steps.map((step, i) => {
      const stepNum = i + 1;
      const complete = stepNum < currentStep;
      const current = stepNum === currentStep;
      return (
        <li
          class:list={[
            'usa-step-indicator__segment',
            complete && 'usa-step-indicator__segment--complete',
            current && 'usa-step-indicator__segment--current',
          ]}
          aria-current={current ? 'step' : undefined}
        >
          <span class="usa-step-indicator__segment-label">
            {step.label}
            {complete && (
              <span class="usa-sr-only">completed</span>
            )}
          </span>
        </li>
      );
    })}
  </ol>
  <div class="usa-step-indicator__header">
    <h2 class="usa-step-indicator__heading">
      <span class="usa-step-indicator__heading-counter">
        <span class="usa-sr-only">Step</span>
        <span class="usa-step-indicator__current-step">{currentStep}</span>
        <span class="usa-step-indicator__total-pages"> of {steps.length}</span>
      </span>
      <span class="usa-step-indicator__heading-text">
        {steps[currentStep - 1]?.label}
      </span>
    </h2>
  </div>
</div>
