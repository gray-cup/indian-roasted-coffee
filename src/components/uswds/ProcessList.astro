---
/**
 * ProcessList — usa-process-list
 * https://designsystem.digital.gov/components/process-list/
 *
 * Numbered, step-by-step list for "how to apply" and similar flows.
 *
 * Usage (slot-based, with ProcessListItem):
 *   <ProcessList>
 *     <ProcessListItem heading="Step one">Description.</ProcessListItem>
 *   </ProcessList>
 *
 * Or with data array:
 *   <ProcessList steps={[{ heading: 'Step 1', content: 'Do this.' }]} />
 */

interface Step {
  heading: string;
  /**
   * Rendered as raw HTML via set:html — NEVER pass unsanitized
   * user- or CMS-supplied content here (XSS risk). For untrusted
   * content, use the slot-based <ProcessListItem> API with text children.
   */
  content: string;
}

interface Props {
  steps?: Step[];
  class?: string;
}

const { steps, class: className } = Astro.props;
---

<ol class:list={['usa-process-list', className]}>
  {steps ? (
    steps.map((step) => (
      <li class="usa-process-list__item">
        <h3 class="usa-process-list__heading">{step.heading}</h3>
        <p set:html={step.content} />
      </li>
    ))
  ) : (
    <slot />
  )}
</ol>
