---
interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;
const prefix = locale === 'es' ? '/es' : '';
const base = import.meta.env.BASE_URL;
const label = locale === 'es' ? 'Carrito' : 'Cart';
---

<a
  href={`${base}cart/`}
  class="cart-btn usa-button usa-button--unstyled"
  id="cart-nav-btn"
  aria-label={`${label} (0 items)`}
>
  <img
    src={`${base}uswds/img/usa-icons/shopping_basket.svg`}
    alt=""
    aria-hidden="true"
    class="cart-btn__icon"
    width="20"
    height="20"
  />
  <span class="cart-btn__label">{label}</span>
  <span
    class="cart-btn__badge"
    id="cart-nav-count"
    aria-hidden="true"
    hidden
  >0</span>
</a>

<style>
  .cart-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    position: relative;
    color: inherit;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .cart-btn:hover {
    text-decoration: underline;
  }
  .cart-btn__icon {
    display: block;
    flex-shrink: 0;
  }
  .cart-btn__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #e52207; /* usa-secondary-vivid */
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1;
    min-width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    padding: 0 0.25rem;
  }
</style>

<script>
  const CART_KEY = 'irc_cart';

  function getCount(): number {
    try {
      const cart: Array<{ quantity: number }> = JSON.parse(
        localStorage.getItem(CART_KEY) || '[]'
      );
      return cart.reduce((s, i) => s + i.quantity, 0);
    } catch {
      return 0;
    }
  }

  function sync() {
    const count = getCount();
    const btn = document.getElementById('cart-nav-btn');
    const badge = document.getElementById('cart-nav-count');
    if (!btn || !badge) return;
    const label = btn.getAttribute('aria-label')?.replace(/\(.*\)/, '').trim() ?? 'Cart';
    btn.setAttribute('aria-label', `${label} (${count} item${count === 1 ? '' : 's'})`);
    badge.textContent = String(count);
    if (count > 0) {
      badge.removeAttribute('hidden');
    } else {
      badge.setAttribute('hidden', '');
    }
  }

  sync();
  window.addEventListener('cart:updated', sync);
  window.addEventListener('storage', (e) => { if (e.key === CART_KEY) sync(); });
</script>
