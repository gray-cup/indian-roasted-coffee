---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLocaleFromUrl, withBase } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout
  title={t('404.heading')}
  locale={locale}
>
  <div class="grid-container usa-section">
    <div class="grid-row">
      <div class="grid-col-12 tablet:grid-col-8 tablet:grid-offset-2">
        <h1>{t('404.heading')}</h1>
        <p class="usa-intro">{t('404.body')}</p>
        <div class="usa-prose">
          <p>You can:</p>
          <ul>
            <li>
              <a href={withBase(locale === 'es' ? '/es/' : '/')} class="usa-link">
                {t('404.homeCta')}
              </a>
            </li>
            <li>
              <a href={withBase(locale === 'es' ? '/es/help/' : '/help/')} class="usa-link">
                {t('404.helpCta')}
              </a>
            </li>
            <li>
              <a href={withBase(locale === 'es' ? '/es/contact/' : '/contact/')} class="usa-link">
                {locale === 'es' ? 'Contáctenos' : 'Contact us for help'}
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
