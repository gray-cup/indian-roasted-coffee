---
// Internal component preview — excluded from sitemap, not linked from public nav.
// Access at /internal/components/ during local dev to review all USWDS wrappers.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Alert from '../../components/uswds/Alert.astro';
import SiteAlert from '../../components/uswds/SiteAlert.astro';
import Breadcrumb from '../../components/uswds/Breadcrumb.astro';
import Accordion from '../../components/uswds/Accordion.astro';
import AccordionItem from '../../components/uswds/AccordionItem.astro';
import ProcessList from '../../components/uswds/ProcessList.astro';
import ProcessListItem from '../../components/uswds/ProcessListItem.astro';
import SummaryBox from '../../components/uswds/SummaryBox.astro';
import StepIndicator from '../../components/uswds/StepIndicator.astro';
import ServiceCard from '../../components/uswds/ServiceCard.astro';
import Hero from '../../components/uswds/Hero.astro';
import CallToAction from '../../components/uswds/CallToAction.astro';
import SideNav from '../../components/uswds/SideNav.astro';
import Search from '../../components/uswds/Search.astro';
import Tag from '../../components/uswds/Tag.astro';
import Pagination from '../../components/uswds/Pagination.astro';
import { withBase } from '../../i18n/utils';

const components = [
  'Alert / SiteAlert', 'Breadcrumb', 'Accordion', 'ProcessList',
  'SummaryBox', 'StepIndicator', 'ServiceCard', 'Hero', 'CallToAction',
  'SideNav', 'Search', 'Tag', 'Pagination',
];
---

<BaseLayout
  title="Component preview (internal)"
  description="Internal preview of all USWDS component wrappers."
  locale="en"
  noindex
>
  <SiteAlert type="info" heading="Internal page">
    This page is not linked from the public site. It exists for local development review only.
  </SiteAlert>

  <div class="grid-container usa-section">
    <h1>USWDS Component Library</h1>
    <p class="usa-intro">All {components.length} component wrappers built for this starter.</p>

    <nav aria-label="Component sections" class="margin-bottom-6">
      <ul class="usa-list">
        {components.map((name) => (
          <li>
            <a href={`#${name.toLowerCase().replace(/[\s/]+/g, '-')}`} class="usa-link">{name}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- ─── Alert / SiteAlert ─── -->
    <section aria-labelledby="alert-siteAlert-heading" class="margin-bottom-8">
      <h2 id="alert-siteAlert-heading" class="border-bottom border-base-light padding-bottom-1">Alert / SiteAlert</h2>

      <h3 class="font-heading-sm margin-top-4">Alert — info</h3>
      <Alert type="info" heading="Informational alert">This is an info message with a heading.</Alert>

      <h3 class="font-heading-sm margin-top-4">Alert — warning (slim, no icon)</h3>
      <Alert type="warning" slim noIcon>Warning without icon or heading.</Alert>

      <h3 class="font-heading-sm margin-top-4">Alert — success</h3>
      <Alert type="success" heading="Application submitted">Your application has been received.</Alert>

      <h3 class="font-heading-sm margin-top-4">Alert — error</h3>
      <Alert type="error" heading="Something went wrong">Please correct the errors below and try again.</Alert>

      <h3 class="font-heading-sm margin-top-4">SiteAlert — emergency</h3>
      <SiteAlert type="emergency" heading="System maintenance">
        Our online services will be unavailable Saturday 2–6 a.m. ET.{' '}
        <a href={withBase('/contact/')} class="usa-link">Learn more</a>
      </SiteAlert>
    </section>

    <!-- ─── Breadcrumb ─── -->
    <section aria-labelledby="breadcrumb-heading" class="margin-bottom-8">
      <h2 id="breadcrumb-heading" class="border-bottom border-base-light padding-bottom-1">Breadcrumb</h2>
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Services', href: '/services/' },
        { label: 'SNAP Benefits', href: '/services/snap/' },
      ]} />
    </section>

    <!-- ─── Accordion ─── -->
    <section aria-labelledby="accordion-heading" class="margin-bottom-8">
      <h2 id="accordion-heading" class="border-bottom border-base-light padding-bottom-1">Accordion</h2>

      <h3 class="font-heading-sm margin-top-4">Default (multi-selectable)</h3>
      <Accordion multiselectable>
        <AccordionItem heading="What documents do I need?" expanded headingLevel="h4">
          <p>You will need proof of identity, income, and residency.</p>
        </AccordionItem>
        <AccordionItem heading="How long does it take to apply?" headingLevel="h4">
          <p>The online application takes about 20 minutes to complete.</p>
        </AccordionItem>
        <AccordionItem heading="Can I apply in person?" headingLevel="h4">
          <p>Yes. Visit any of our offices Monday through Friday, 8 a.m. to 5 p.m.</p>
        </AccordionItem>
      </Accordion>

      <h3 class="font-heading-sm margin-top-4">Bordered</h3>
      <Accordion bordered>
        <AccordionItem heading="Bordered accordion item" headingLevel="h4">
          <p>Content inside a bordered accordion.</p>
        </AccordionItem>
      </Accordion>
    </section>

    <!-- ─── ProcessList ─── -->
    <section aria-labelledby="processlist-heading" class="margin-bottom-8">
      <h2 id="processlist-heading" class="border-bottom border-base-light padding-bottom-1">ProcessList</h2>
      <ProcessList>
        <ProcessListItem heading="Check eligibility" headingLevel="h3">
          <p>Answer a few questions to see which programs you may qualify for.</p>
        </ProcessListItem>
        <ProcessListItem heading="Gather documents" headingLevel="h3">
          <p>You may need proof of identity, income, and residency.</p>
        </ProcessListItem>
        <ProcessListItem heading="Submit your application" headingLevel="h3">
          <p>Apply online in about 20 minutes.</p>
        </ProcessListItem>
      </ProcessList>
    </section>

    <!-- ─── SummaryBox ─── -->
    <section aria-labelledby="summarybox-heading" class="margin-bottom-8">
      <h2 id="summarybox-heading" class="border-bottom border-base-light padding-bottom-1">SummaryBox</h2>
      <div class="grid-row grid-gap">
        <div class="grid-col-12 tablet:grid-col-6">
          <SummaryBox heading="Eligibility at a glance" label="Eligibility at a glance">
            <dl>
              <dt class="text-bold">Age</dt>
              <dd class="margin-left-0 margin-bottom-1">18 or older</dd>
              <dt class="text-bold">Income</dt>
              <dd class="margin-left-0 margin-bottom-1">Below 130% FPL</dd>
              <dt class="text-bold">Residency</dt>
              <dd class="margin-left-0">State resident</dd>
            </dl>
          </SummaryBox>
        </div>
        <div class="grid-col-12 tablet:grid-col-6">
          <SummaryBox heading="Still need help?">
            <p>Call us at <a href="tel:18005550100" class="usa-link">1&#8209;800&#8209;555&#8209;0100</a></p>
            <p class="font-sans-sm text-base-dark">Monday–Friday, 8 a.m.–8 p.m. ET</p>
            <a href={withBase('/contact/')} class="usa-button usa-button--outline">Send a message</a>
          </SummaryBox>
        </div>
      </div>
    </section>

    <!-- ─── StepIndicator ─── -->
    <section aria-labelledby="stepindicator-heading" class="margin-bottom-8">
      <h2 id="stepindicator-heading" class="border-bottom border-base-light padding-bottom-1">StepIndicator</h2>

      <h3 class="font-heading-sm margin-top-4">Step 2 of 5 (with counters)</h3>
      <StepIndicator
        steps={[
          { label: 'Eligibility check' },
          { label: 'Personal information' },
          { label: 'Household & income' },
          { label: 'Documents' },
          { label: 'Review & submit' },
        ]}
        currentStep={2}
        counters
      />

      <h3 class="font-heading-sm margin-top-4">Centered, small counters</h3>
      <StepIndicator
        steps={[
          { label: 'Start' },
          { label: 'Details' },
          { label: 'Review' },
        ]}
        currentStep={1}
        countersSm
        centered
      />
    </section>

    <!-- ─── ServiceCard ─── -->
    <section aria-labelledby="servicecard-heading" class="margin-bottom-8">
      <h2 id="servicecard-heading" class="border-bottom border-base-light padding-bottom-1">ServiceCard</h2>
      <ul class="usa-card-group">
        <ServiceCard
          title="SNAP Benefits"
          summary="Monthly funds for purchasing groceries for eligible low-income households."
          href="/services/snap/"
          ctaText="Learn more"
          acceptingApplications={true}
          class="tablet:grid-col-4"
        />
        <ServiceCard
          title="Medicaid"
          summary="Low- or no-cost health coverage for eligible individuals and families."
          href="/services/medicaid/"
          ctaText="Learn more"
          acceptingApplications={true}
          class="tablet:grid-col-4"
        />
        <ServiceCard
          title="WIC"
          summary="Nutrition support program — currently not accepting new applications."
          href="/services/wic/"
          ctaText="Learn more"
          acceptingApplications={false}
          class="tablet:grid-col-4"
        />
      </ul>
    </section>

    <!-- ─── Hero ─── -->
    <section aria-labelledby="hero-heading-preview" class="margin-bottom-8">
      <h2 id="hero-heading-preview" class="border-bottom border-base-light padding-bottom-1">Hero</h2>

      <h3 class="font-heading-sm margin-top-4">Small hero (section header style)</h3>
      <Hero
        heading="Programs &amp; services"
        subheading="We offer assistance programs for eligible residents."
        label="Services"
        small
      />

      <h3 class="font-heading-sm margin-top-4">Full hero with CTA</h3>
      <Hero
        heading="Benefits that work"
        headingSuffix="for you."
        subheading="Find food, health, and childcare support programs you may qualify for."
        ctaText="Check eligibility"
        ctaHref="/services/"
        label="Homepage"
      />
    </section>

    <!-- ─── CallToAction ─── -->
    <section aria-labelledby="cta-section-heading" class="margin-bottom-8">
      <h2 id="cta-section-heading" class="border-bottom border-base-light padding-bottom-1">CallToAction</h2>
      <CallToAction
        heading="Ready to apply?"
        primaryCta={{ label: 'Start application', href: '/services/' }}
        secondaryCta={{ label: 'Learn more', href: '/help/' }}
      >
        <p>The process takes about 20 minutes. You'll get a decision within 30 days.</p>
      </CallToAction>
    </section>

    <!-- ─── SideNav ─── -->
    <section aria-labelledby="sidenav-heading" class="margin-bottom-8">
      <h2 id="sidenav-heading" class="border-bottom border-base-light padding-bottom-1">SideNav</h2>
      <div class="grid-row grid-gap">
        <div class="grid-col-12 tablet:grid-col-4">
          <SideNav
            label="Help topics"
            items={[
              { label: 'General questions', href: '#general' },
              {
                label: 'SNAP questions',
                href: '#snap',
                children: [
                  { label: 'Eligibility', href: '#snap-eligibility' },
                  { label: 'How to apply', href: '#snap-apply' },
                ],
              },
              { label: 'Contact us', href: '/contact/' },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- ─── Search ─── -->
    <section aria-labelledby="search-heading" class="margin-bottom-8">
      <h2 id="search-heading" class="border-bottom border-base-light padding-bottom-1">Search</h2>

      <h3 class="font-heading-sm margin-top-4">Default</h3>
      <Search label="Search help topics" action="/search" />

      <h3 class="font-heading-sm margin-top-4">Big</h3>
      <Search label="Search the site" action="/search" size="big" />

      <h3 class="font-heading-sm margin-top-4">Small</h3>
      <Search label="Quick search" action="/search" size="small" />
    </section>

    <!-- ─── Tag ─── -->
    <section aria-labelledby="tag-heading" class="margin-bottom-8">
      <h2 id="tag-heading" class="border-bottom border-base-light padding-bottom-1">Tag</h2>
      <div class="display-flex gap-2 flex-wrap margin-top-2">
        <Tag>Default</Tag>
        <Tag big>Big tag</Tag>
        <Tag color="base-light">Base light</Tag>
        <Tag color="primary-lighter">Primary lighter</Tag>
        <Tag color="secondary-lighter">Secondary lighter</Tag>
        <Tag color="accent-cool-lighter">Accent cool</Tag>
        <Tag color="accent-warm-lighter">Accent warm</Tag>
        <Tag color="error-lighter">Error</Tag>
        <Tag color="warning-lighter">Warning</Tag>
        <Tag color="success-lighter">Success</Tag>
      </div>
    </section>

    <!-- ─── Pagination ─── -->
    <section aria-labelledby="pagination-heading" class="margin-bottom-8">
      <h2 id="pagination-heading" class="border-bottom border-base-light padding-bottom-1">Pagination</h2>

      <h3 class="font-heading-sm margin-top-4">Page 1 of 10</h3>
      <Pagination totalPages={10} currentPage={1} urlPattern="/news/page/%d/" label="Page 1 of 10 example" />

      <h3 class="font-heading-sm margin-top-4">Page 5 of 10 (middle — ellipsis on both sides)</h3>
      <Pagination totalPages={10} currentPage={5} urlPattern="/news/page/%d/" label="Page 5 of 10 example" />

      <h3 class="font-heading-sm margin-top-4">Page 10 of 10 (last)</h3>
      <Pagination totalPages={10} currentPage={10} urlPattern="/news/page/%d/" label="Page 10 of 10 example" />
    </section>
  </div>
</BaseLayout>
