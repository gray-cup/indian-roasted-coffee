---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/uswds/Breadcrumb.astro';
import Alert from '../components/uswds/Alert.astro';
import SummaryBox from '../components/uswds/SummaryBox.astro';
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  breadcrumbs?: BreadcrumbItem[];
  acceptingApplications?: boolean;
  applyHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  locale = 'en',
  breadcrumbs = [],
  acceptingApplications = true,
  applyHref,
  imageSrc,
  imageAlt = '',
} = Astro.props;

const t = useTranslations(locale);
const allCrumbs = [
  { label: locale === 'es' ? 'Inicio' : 'Home', href: locale === 'es' ? '/es/' : '/' },
  { label: locale === 'es' ? 'Productos' : 'Products', href: locale === 'es' ? '/es/services/' : '/services/' },
  ...breadcrumbs,
];
---

<BaseLayout title={title} description={description} locale={locale}>
  <div class="grid-container usa-section">
    <Breadcrumb items={allCrumbs} wrap />
    <div class="grid-row grid-gap">
      <div class="grid-col-12 tablet:grid-col-8">
        {!acceptingApplications && (
          <Alert type="warning" slim>
            {locale === 'es'
              ? 'Este producto no está disponible actualmente.'
              : 'This product is not currently available.'}
          </Alert>
        )}

        <h1>{title}</h1>
        {imageSrc && (
          <img
            src={imageSrc}
            alt={imageAlt}
            style="width: 100%; max-height: 160px; object-fit: cover; object-position: center; display: block; border-radius: 4px; margin-bottom: 1.5rem;"
            loading="eager"
          />
        )}
        <div class="usa-prose">
          <slot />
        </div>
      </div>

      <div class="grid-col-12 tablet:grid-col-4">
        <slot name="sidebar" />

        {applyHref && acceptingApplications && (
          <SummaryBox
            heading={locale === 'es' ? 'Listo para ordenar' : 'Ready to order?'}
            label={locale === 'es' ? 'Listo para ordenar' : 'Ready to order?'}
            class="margin-top-4"
          >
            <p>
              {locale === 'es'
                ? 'Roasted to order and shipped within 48 hours.'
                : 'Roasted to order and shipped within 48 hours.'}
            </p>
            <a href={applyHref} class="usa-button usa-button--big">
              {t('home.applyNow')}
            </a>
          </SummaryBox>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
