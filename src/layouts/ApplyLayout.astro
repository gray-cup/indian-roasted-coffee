---
import BaseLayout from './BaseLayout.astro';
import StepIndicator from '../components/uswds/StepIndicator.astro';
import type { Locale } from '../i18n/utils';

interface Step {
  label: string;
}

interface Props {
  title: string;
  programName: string;
  locale?: Locale;
  steps: Step[];
  currentStep: number;
}

const { title, programName, locale = 'en', steps, currentStep } = Astro.props;
---

<BaseLayout title={title} locale={locale}>
  <div class="bg-primary-dark padding-y-2">
    <div class="grid-container">
      <p class="text-white margin-0 font-sans-sm">
        {locale === 'es' ? 'Pedido:' : 'Order:'} <strong>{programName}</strong>
      </p>
    </div>
  </div>

  <div class="grid-container usa-section">
    <h1>{title}</h1>

    <StepIndicator
      steps={steps}
      currentStep={currentStep}
      countersSm
      label={locale === 'es' ? 'Pasos del pedido' : 'Order steps'}
    />

    <div class="grid-row grid-gap margin-top-4">
      <div class="grid-col-12 tablet:grid-col-8">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
