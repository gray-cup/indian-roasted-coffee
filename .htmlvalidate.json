{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-trailing-whitespace": "off",
    "long-title": "off",
    "require-sri": "off",
    "no-unknown-elements": "off",
    "prefer-native-element": "off",
    "aria-label-misuse": "warn",
    "missing-doctype": "error",
    "void-style": "off",
    "heading-level": "error",
    "input-missing-label": "error",
    "wcag/h30": "error",
    "wcag/h32": "error",
    "wcag/h36": "error",
    "wcag/h37": "error",
    "wcag/h63": "error",
    "wcag/h67": "error",
    "wcag/h71": "error"
  }
}
