{
  "name": "astro-gov-starter",
  "type": "module",
  "version": "0.1.0",
  "description": "Production-ready Astro starter for government service websites. USWDS-native, accessible by default, privacy-respecting.",
  "keywords": [
    "astro",
    "uswds",
    "government",
    "accessibility",
    "508",
    "wcag"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.17.1"
  },
  "scripts": {
    "dev": "node scripts/setup-uswds.mjs && astro dev",
    "build": "node scripts/setup-uswds.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "setup": "node scripts/setup-uswds.mjs",
    "ci:check": "bash scripts/check.sh",
    "init-agency": "node scripts/init-agency.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@uswds/uswds": "^3.10.0",
    "astro": "^6.0.0",
    "astro-llms-generate": "^1.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "html-validate": "^10.13.0",
    "linkinator": "^7.6.1",
    "pagefind": "^1.5.2",
    "sass": "^1.77.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
