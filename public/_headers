# Security response headers for Netlify and Cloudflare Pages deployments.
#
# These supplement the Content-Security-Policy <meta> tag that Astro generates
# at build time. Certain directives — particularly frame-ancestors — are silently
# ignored by browsers when set in a <meta> tag; they MUST be HTTP response headers.
#
# Translating to other hosting platforms:
#   Vercel          → vercel.json  "headers" array
#   AWS CloudFront  → Response Headers Policy (CloudFront console or CDK)
#   Apache          → Header directives in .htaccess
#   nginx           → add_header directives in your server block

/*
  # Prevent clickjacking — must be an HTTP header; <meta> CSP cannot enforce this.
  # Change 'none' to 'self' if you need the site to be embeddable in your own iframes.
  Content-Security-Policy: frame-ancestors 'none'

  # Legacy clickjacking protection for browsers that predate CSP frame-ancestors.
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing attacks.
  X-Content-Type-Options: nosniff

  # Send full URL as referrer within the same origin; send only the bare origin
  # when navigating cross-site (hides full paths from third-party servers).
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser features your site does not use.
  # Remove a restriction only if a specific page feature requires it.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # Uncomment once you are confident the site is fully on HTTPS.
  # Start with a short max-age (300s) and increase to 31536000 after validating.
  # Add includeSubDomains and preload only after all subdomains are HTTPS-ready.
  # Strict-Transport-Security: max-age=300; includeSubDomains
